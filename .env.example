# Anthropic (required — Claude Code CLI auth)
ANTHROPIC_API_KEY=

# Netlify (required — deploy briefs and update existing sites)
NETLIFY_AUTH_TOKEN=

# DataForSEO
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=

# Bright Data
BRIGHTDATA_API_TOKEN=

# Apify
APIFY_API_TOKEN=

# Slack (optional — posts brief-ready notification with Netlify link)
SLACK_WEBHOOK_URL=

# Server
PORT=3000
